---
import { cva } from "class-variance-authority";

import Link from "@/components/Link.svelte";
import SvelteIcon from "@/components/SvelteIcon.svelte";
import Card from "@/components/ui/card/Card.astro";
import CardDescription from "@/components/ui/card/CardDescription.astro";
import CardHeader from "@/components/ui/card/CardHeader.astro";
import CardTitle from "@/components/ui/card/CardTitle.astro";
import { ChevronLeftIcon, ChevronRightIcon } from "@/config/icons.svelte";
import { cn } from "@/lib/utils";

interface Props {
  position: "previous" | "next";
  slug: string;
  title: string;
}

const { position, slug, title } = Astro.props;

const navItemVariants = cva(
  "group col-span-1 no-underline transition-opacity hover:opacity-80",
  {
    variants: {
      position: {
        previous: "col-start-1",
        next: "col-start-2",
      },
    },
  },
);

const cardHeaderVariants = cva("gap-1", {
  variants: {
    position: {
      previous: "items-start",
      next: "items-end text-right",
    },
  },
});

const labelVariants = cva(
  "flex items-center gap-1 text-xs font-medium tracking-widest text-muted-foreground uppercase",
  {
    variants: {
      position: {
        previous: "flex-row",
        next: "flex-row-reverse",
      },
    },
  },
);

const LABEL = {
  previous: {
    text: "Previous",
    icon: ChevronLeftIcon,
  },
  next: {
    text: "Next",
    icon: ChevronRightIcon,
  },
} as const;

const { text, icon } = LABEL[position];
---

<Link class={cn(navItemVariants({ position }))} href={`/blog/${slug}`}>
  <Card>
    <CardHeader class={cn(cardHeaderVariants({ position }))}>
      <CardTitle class={cn(labelVariants({ position }))}>
        <SvelteIcon {icon} />
        {text}
      </CardTitle>
      <CardDescription>{title}</CardDescription>
    </CardHeader>
  </Card>
</Link>
