---
import { info } from "@/config/constants";
import { ExternalLink } from "./link";
import { ThemeToggle } from "./theme-toggle";
import { buttonVariants } from "./ui/button";

const year = new Date().getFullYear();

const footerLinks = {
  Product: [
    { label: "Features", href: "#" },
    { label: "Pricing", href: "#" },
    { label: "Changelog", href: "#", badge: "New" },
    { label: "Roadmap", href: "#" },
  ],
  Resources: [
    { label: "Documentation", href: "#" },
    { label: "API Reference", href: "#" },
    { label: "Blog", href: "#" },
    { label: "Status", href: "#" },
  ],
  Company: [
    { label: "About", href: "#" },
    { label: "Careers", href: "#" },
    { label: "Privacy", href: "#" },
    { label: "Terms", href: "#" },
  ],
};
---

<footer class="border-t py-8">
  <div class="mx-auto max-w-3xl px-10">
    {/* Top grid */}
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">
      {
        Object.entries(footerLinks).map(([group, links]) => (
          <div>
            <span class="text-sm font-medium">{group}</span>
            <nav>
              <ul class="mt-3.5 space-y-1.5">
                {links.map((link) => (
                  <li>
                    <ExternalLink
                      href={link.href}
                      className="text-sm text-muted-foreground transition-colors hover:text-foreground"
                    >
                      {link.label}
                    </ExternalLink>
                  </li>
                ))}
              </ul>
            </nav>
          </div>
        ))
      }
    </div>

    {/* Bottom grid */}
    <div class="mt-10 flex flex-row items-center justify-between gap-4">
      <div class="">
        <p class="text-sm text-muted-foreground">
          {`© ${year} ${info.firstName} ${info.lastName}`}
        </p>
        <div class="flex items-center gap-1">
          {
            info.socials.map((item) => (
              <ExternalLink
                key={item.label}
                href={item.href}
                aria-label={item.label}
                className={buttonVariants({ variant: "ghost", size: "icon" })}
              >
                <item.icon />
              </ExternalLink>
            ))
          }
        </div>
      </div>

      <ThemeToggle client:load />
    </div>
  </div>
</footer>
