---
import Link from "@/components/Link.svelte";
import { FOOTER_ITEMS } from "@/config/navigation-items.svelte";
---

{
  Object.entries(FOOTER_ITEMS).map(([group, links]) => (
    <div>
      <span class="text-sm font-medium">{group}</span>
      <nav>
        <ul class="mt-3.5 space-y-1.5">
          {links.map((link) => (
            <li>
              <Link
                class="text-sm text-muted-foreground transition-colors hover:text-foreground"
                href={link.href}
              >
                {link.label}
              </Link>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  ))
}
